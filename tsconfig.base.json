{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@nexian/core/*": ["packages/core/src/*"],
      "@nexian/connectors/*": ["packages/connectors/src/*"],
      "@nexian/config/*": ["packages/config/*"],
      "@nexian/ui/*": ["packages/ui/*"]
    }
  }
}

