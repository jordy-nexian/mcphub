{
  "name": "nexian-mcp-hub",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.8.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @nexian/api prisma:generate",
    "db:migrate": "pnpm --filter @nexian/api prisma:push"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "turbo": "^2.0.14",
    "typescript": "^5.6.3"
  }
}
